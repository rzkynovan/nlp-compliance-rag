# ============================================================
# Backend — Template Environment Variables
# Salin file ini: cp backend/.env.example backend/.env
# ============================================================

OPENAI_API_KEY=sk-your-openai-api-key-here
LLAMA_CLOUD_API_KEY=llx-your-llamaparse-api-key-here

REDIS_URL=redis://localhost:6379/0
MLFLOW_TRACKING_URI=http://localhost:5000

CHROMADB_PERSIST_DIR=../data/processed/chroma_db
CHROMADB_COLLECTION_BI=bi_regulations
CHROMADB_COLLECTION_OJK=ojk_regulations

LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-large
LLM_TEMPERATURE=0.1
RETRIEVAL_TOP_K=5

COST_OPTIMIZATION_MODE=development
DAILY_BUDGET_LIMIT_USD=5.0
ENABLE_CACHE=true
CACHE_TTL_HOURS=24

RATE_LIMIT_REQUESTS_PER_MINUTE=10
RATE_LIMIT_TOKENS_PER_MINUTE=100000
