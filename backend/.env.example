# Copy this file to .env and fill in your API keys

# Required: OpenAI API Key
OPENAI_API_KEY=sk-your-openai-api-key-here

# Required: LlamaParse API Key
LLAMAPARSE_API_KEY=llx-your-llamaparse-api-key-here

# Optional: Database URL (PostgreSQL)
# DATABASE_URL=postgresql://compliance:compliance123@localhost:5432/compliance_db

# Optional: Redis URL
REDIS_URL=redis://localhost:6379/0

# Optional: MLflow Tracking URI
MLFLOW_TRACKING_URI=http://localhost:5000

# ChromaDB Settings
# CHROMADB_PERSIST_DIR=./data/chromadb
# CHROMADB_COLLECTION_BI=bi_regulations
# CHROMADB_COLLECTION_OJK=ojk_regulations

# LLM Settings (COST OPTIMIZATION)
# Use gpt-4o-mini for development (20x cheaper!)
# Switch to gpt-4o for production
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
LLM_TEMPERATURE=0.1
RETRIEVAL_TOP_K=5

# Cost Optimization
COST_OPTIMIZATION_MODE=development
DAILY_BUDGET_LIMIT_USD=5.0
ENABLE_CACHE=true
CACHE_TTL_HOURS=24

# Rate Limiting (protect API quota)
RATE_LIMIT_REQUESTS_PER_MINUTE=10
RATE_LIMIT_TOKENS_PER_MINUTE=100000