# ============================================================
# Docker — Environment Variables Template
# Salin file ini: cp .env.example .env
# Lalu isi nilai yang sesuai
# ============================================================

# --- API Keys (WAJIB diisi) ---
OPENAI_API_KEY=sk-proj-xxxxx
LLAMA_CLOUD_API_KEY=llx-xxxxx

# --- Database & Cache ---
REDIS_URL=redis://redis:6379/0
MLFLOW_TRACKING_URI=http://mlflow:5000

# --- ChromaDB (path di dalam container) ---
CHROMADB_PERSIST_DIR=/app/data/processed/chroma_db
CHROMADB_COLLECTION_BI=bi_regulations
CHROMADB_COLLECTION_OJK=ojk_regulations

# --- LLM & Embedding ---
# CATATAN: ChromaDB collections dibangun dengan text-embedding-3-large (3072 dim)
# Jangan ganti ke text-embedding-3-small tanpa rebuild collections (--force)
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-large
LLM_TEMPERATURE=0.1
RETRIEVAL_TOP_K=5

# --- Cost Optimization ---
COST_OPTIMIZATION_MODE=development
DAILY_BUDGET_LIMIT_USD=5.0
ENABLE_CACHE=true
CACHE_TTL_HOURS=24

# --- Rate Limiting ---
RATE_LIMIT_REQUESTS_PER_MINUTE=10
RATE_LIMIT_TOKENS_PER_MINUTE=100000

# --- CORS & URL ---
# Untuk server: ganti dengan IP/domain server
# Contoh server:  ALLOWED_ORIGINS=http://144.126.136.57:3000
# Contoh lokal:   ALLOWED_ORIGINS=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# URL backend yang digunakan oleh frontend (build-time variable)
# Untuk server: ganti dengan IP/domain server
# Contoh server:  NEXT_PUBLIC_API_URL=http://144.126.136.57:8000/api/v1
# Contoh lokal:   NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
