# ============================================================
# NLP Compliance Audit RAG — Template Environment Variables
# Salin file ini: cp .env.example .env
# ============================================================

# --- API Keys ---
OPENAI_API_KEY=sk-your-openai-api-key-here

# LlamaParse — nama resmi dari SDK LlamaIndex Cloud
# Daftar di: https://cloud.llamaindex.ai
LLAMA_CLOUD_API_KEY=llx-your-llamaparse-api-key-here

# --- Database & Cache ---
REDIS_URL=redis://localhost:6379/0
MLFLOW_TRACKING_URI=http://localhost:5000

# --- ChromaDB ---
CHROMADB_PERSIST_DIR=./data/processed/chroma_db
CHROMADB_COLLECTION_BI=bi_regulations
CHROMADB_COLLECTION_OJK=ojk_regulations

# --- LLM & Embedding ---
# PENTING: Gunakan model yang sama dengan saat ingest.
# ChromaDB collections default dibangun dengan text-embedding-3-large (3072 dim).
# Jika ingin pakai text-embedding-3-small, rebuild dengan: python src/ingest.py --force
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-large
LLM_TEMPERATURE=0.1
RETRIEVAL_TOP_K=5

# --- Cost Optimization ---
COST_OPTIMIZATION_MODE=development
DAILY_BUDGET_LIMIT_USD=5.0
ENABLE_CACHE=true
CACHE_TTL_HOURS=24

# --- Rate Limiting ---
RATE_LIMIT_REQUESTS_PER_MINUTE=10
RATE_LIMIT_TOKENS_PER_MINUTE=100000
